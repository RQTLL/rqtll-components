* {
  margin: 0;
  padding: 0;
  border: 0;
  font-family: "Nunito Sans";
  background: #ffffff;
  color: #000000;
}

/* status colors */
.status-success { color: #068989; }
.status-warning { color: #e5a436; }
.status-error { color: #ff4f5e; }

/* Small utility */
.muted { color: #6b6b6b; }

#MainContainer {
  background-color: white;
  padding: 2px;
}

#MainContainer[state="normal"] {
  border-radius: 14px;
  border: 1px solid rgba(0, 0, 0, 8%);
}

#MainContainer[state="maximized"] {
  border-radius: 0px;
  border: none;
}

#TitleBar {
  margin: 0;
}

#Content {
  background: transparent;
  border: none;
  padding: 0;
}

QWidget {
  selection-background-color: #0090ff;
  selection-color: #000000;
}

QPushButton[role="close"][variant="default"]
{
  background: #e5e5e5;
  color: #000000;
  border: 1px solid #d5d5d5;
  border-radius: 6px;
  padding: 8px;
}

QPushButton[role="close"][variant="default"]:hover {
  background: #e6e6e6;
  border: 2px solid #ff4f5e;
}

QPushButton[role="close"][variant="default"]:pressed {
  background: #ff4f5e;
  color: #000000;
}

QPushButton[role="close"][variant="default"]:disabled {
  background: #d9d9d9;
  color: #222222;
  border-color: #c8c8c8;
}

QPushButton
{
  background: #e5e5e5;
  color: #000000;
  border: 1px solid #d5d5d5;
  border-radius: 6px;
  padding: 8px;
}

QFrame[role="frame-button"][variant="default"] * {
  background: transparent;
}

QFrame[role="frame-button"][variant="default"] {
  background: #e5e5e5;
  color: #000000;
  border: 1px solid #d5d5d5;
  border-radius: 14px;
  padding: 6px;
}

QWidget[role="in-tab"][variant="default"] QFrame[role="frame-button"][variant="default"] {
  background: #e5e5e5;
  border: 1px solid #d5d5d5;
}

QFrame[role="frame-button"][variant="default"]:hover,
QPushButton:hover {
  background: #e6e6e6;
  border: 2px solid #0090ff;
}

QWidget[role="in-tab"][variant="default"] QFrame[role="frame-button"][variant="default"]:hover {
  background: #e6e6e6;
  border: 2px solid #0090ff;
}

QFrame[role="frame-button"][variant="default"][state="pressed"],
QPushButton:pressed {
  background: #0090ff;
  color: #000000;
}

QFrame[role="frame-button"][variant="default"][state="checked"] {
  background: #0090ff;
  border: 2px solid #0090ff;
}

QWidget[role="in-tab"][variant="default"] QFrame[role="frame-button"][variant="default"][state="checked"] {
  background: #0090ff;
  border: 2px solid #0090ff;
}

QFrame[role="frame-button"][variant="default"][state="dissabled"],
QPushButton:disabled {
  background: #d9d9d9;
  color: #222222;
  border-color: #c8c8c8;
}

QLineEdit, QTextEdit, QPlainTextEdit, QSpinBox, QDoubleSpinBox {
  background: #f5f5f5;
  border: 1px solid #e0e0e0;
  border-radius: 6px;
  padding: 4px;
  color: #000000;
}

QSpinBox::up-button,
QSpinBox::down-button,
QDoubleSpinBox::up-button,
QDoubleSpinBox::down-button
{
  background-color: #0090ff;
  border: none;
  padding: 2px;
  margin-top: 1px;
  margin-bottom: 1px;
  margin-right: 2px;
  border-radius: 4px;
}

QSpinBox::up-button:hover,
QSpinBox::down-button:hover,
QDoubleSpinBox::up-button:hover,
QDoubleSpinBox::down-button:hover
{
  background-color: #0080df;
}

QSpinBox::up-button:pressed,
QSpinBox::down-button:pressed,
QDoubleSpinBox::up-button:pressed,
QDoubleSpinBox::down-button:pressed
{
  background-color: #ffffff;
}


QScrollBar {
  background: #f5f5f5;
  border: none;
}

QScrollBar:vertical {
  border-radius: 6px;
  width: 12px;
}

QScrollBar::horizontal {
  border-radius: 6px;
  height: 12px;
}

QScrollBar::handle:vertical,
QScrollBar::handle:horizontal {
  background: #c6c6c6;
  border-radius: 6px;
}

QScrollBar::handle:vertical:hover,
QScrollBar::handle:horizontal:hover {
  background: #0090ff;
}

QScrollBar::handle:vertical:pressed,
QScrollBar::handle:horizontal:pressed {
  background: #0080df;
}

QScrollBar::handle:vertical:disabled,
QScrollBar::handle:horizontal:disabled {
  background: #d9d9d9;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical,
QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal {
  background: transparent;
  border: none;
}

QWidget[role="in-tab"][variant="default"] {
  background: #f5f5f5;
  border: 1px solid #e0e0e0;
  border-top-right-radius: 14px;
  border-bottom-left-radius: 14px;
  border-bottom-right-radius: 14px;
}

QWidget[role="in-tab"][variant="default"] QWidget {
  background: #f5f5f5;
}

QWidget[role="in-tab"][variant="default"] QLineEdit,
QWidget[role="in-tab"][variant="default"] QSpinBox,
QWidget[role="in-tab"][variant="default"] QDoubleSpinBox,
QWidget[role="in-tab"][variant="default"] QComboBox {
  padding: 4px;
  border-radius: 6px;
  background: #ffffff;
  color: #000000;
}

QWidget[role="in-tab"][variant="default"] QPushButton,
QWidget[role="in-tab"][variant="default"] QPushButton:hover
{
  background: #ffffff;
}

QGroupBox {
  background: transparent;
  padding-top: 18px;
  padding-left: 2px;
  padding-right: 2px;
  padding-bottom: 2px;
  color: #000000;
  border-radius: 8px;
  border: 1px solid #d5d5d5;
}

QTabBar::tab {
  background: transparent;
  padding: 6px 10px;
}

QTabBar::tab:selected {
  background: #0090ff;
  color: #000000;
  border-top-left-radius: 6px;
  border-top-right-radius: 6px;
}

QTabBar::tab:!selected {
  background: #e5e5e5;
  color: #000000;
  border: 1px solid #d5d5d5;
  border-bottom: none;
  border-top-left-radius: 6px;
  border-top-right-radius: 6px;
}

QTableView {
  background: #f5f5f5;
  border-radius: 6px;
  padding: 4px;
  color: #000000;
  gridline-color: #e0e0e0;
}

QTableView *
{
  border: none;
  background: #f5f5f5;
}

QTableView QHeaderView,
QTableView::item {
  background: #f5f5f5;
  color: #000000;
  border: none;
}

QComboBox {
  combobox-popup: 0;
}

QWidget[role="in-tab"][variant="default"] QComboBox * {
  background: #ffffff;
  color: #000000;
}

QWidget[role="in-tab"][variant="default"] QComboBox:on {
  background: #ffffff;
}

QWidget[role="in-tab"][variant="default"] QComboBox QAbstractItemView {
  background-color: #ffffff;
  border: 2px solid #0090ff;
  selection-background-color: #0078d7; 
  outline: none; 
}

QWidget[role="in-tab"][variant="default"] QComboBox QAbstractItemView::item:hover,
QWidget[role="in-tab"][variant="default"] QComboBox QAbstractItemView::item:selected 
{
  background-color: #0090ff;
  color: #000000;
}

QWidget[role="in-tab"][variant="default"] QSpinBox::up-button,
QWidget[role="in-tab"][variant="default"] QSpinBox::down-button,
QWidget[role="in-tab"][variant="default"] QDoubleSpinBox::up-button,
QWidget[role="in-tab"][variant="default"] QDoubleSpinBox::down-button 
{
  background-color: #0090ff;
  border: none;
  padding: 2px;
  margin-top: 1px;
  margin-bottom: 1px;
  margin-right: 2px;
  border-radius: 4px;
}

QWidget[role="in-tab"][variant="default"] QComboBox::drop-down {
  background-color: #0090ff;
  border-radius: 4px;
  margin: 4px;
  padding: 2px;
  width: 16px;
}

QWidget[role="in-tab"][variant="default"] QComboBox::down-arrow {
  width: 12px;
}

QWidget[role="in-tab"][variant="default"] QComboBox::drop-down:hover,
QWidget[role="in-tab"][variant="default"] QSpinBox::up-button:hover,
QWidget[role="in-tab"][variant="default"] QSpinBox::down-button:hover,
QWidget[role="in-tab"][variant="default"] QDoubleSpinBox::up-button:hover,
QWidget[role="in-tab"][variant="default"] QDoubleSpinBox::down-button:hover
{
  background-color: #0080df;
}

QWidget[role="in-tab"][variant="default"] QComboBox::drop-down:pressed,
QWidget[role="in-tab"][variant="default"] QSpinBox::up-button:pressed,
QWidget[role="in-tab"][variant="default"] QSpinBox::down-button:pressed,
QWidget[role="in-tab"][variant="default"] QDoubleSpinBox::up-button:pressed,
QWidget[role="in-tab"][variant="default"] QDoubleSpinBox::down-button:pressed
{
  background-color: #ffffff;
}

QWidget[role="in-tab"][variant="default"] QWidget[role="node-list"][variant="default"] {
  background: #ffffff;
  border-radius: 6px;
}

QMessageBox {
  background-color: white;
  color: #000000;
  padding: 8px;
  border: 1px solid rgba(0, 0, 0, 8%);
}

